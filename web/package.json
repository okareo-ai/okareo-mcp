{
  "name": "okareo-mcp-embedded-login",
  "version": "0.1.0",
  "private": true,
  "description": "Embedded login/sign-up page for the Okareo MCP — Next.js static export bundled into the MCP container image. Usees Frontegg for authentication and user management.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test --config=playwright.config.ts --grep @visual",
    "test:e2e": "playwright test --config=playwright.config.ts --grep @e2e",
    "test:a11y": "playwright test --config=playwright.config.ts --grep @a11y",
    "check:secrets": "bash ../scripts/check-bundle-secrets.sh"
  },
  "dependencies": {
    "@frontegg/react": "7.13.6",
    "@mantine/core": "7.17.8",
    "@mantine/form": "7.17.8",
    "@mantine/hooks": "7.17.8",
    "@mantine/notifications": "7.17.8",
    "@tabler/icons-react": "^3.20.0",
    "clsx": "^2.1.1",
    "next": "14.2.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.16.0",
    "@types/react": "18.2.34",
    "@types/react-dom": "18.2.14",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.5",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.32",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.0.1"
}
